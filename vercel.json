{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --prefix frontend/digital-twin-dashboard",
  "buildCommand": "npm run build --prefix frontend/digital-twin-dashboard",
  "outputDirectory": "frontend/digital-twin-dashboard/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
